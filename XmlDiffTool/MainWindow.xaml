<Window x:Class="XmlDiffTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:infrastructure="clr-namespace:XmlDiffTool.Infrastructure"
        mc:Ignorable="d"
        Title="XML Diff Tool" Height="600" Width="900">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <infrastructure:IndentationConverter x:Key="IndentationConverter" />
    </Window.Resources>

    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="10" BorderThickness="1" BorderBrush="LightGray" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBox Width="280" Margin="0,0,8,0" Text="{Binding LeftFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                        <Button Content="Browse..." Width="90" Command="{Binding BrowseLeftCommand}" />
                    </StackPanel>

                    <Button Grid.Column="1" Content="Compare" Width="120" Margin="10,0" Command="{Binding CompareCommand}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBox Width="280" Margin="0,0,8,0" Text="{Binding RightFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                        <Button Content="Browse..." Width="90" Command="{Binding BrowseRightCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10" VerticalAlignment="Center">
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Width="240" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Content="Only Show Different Parameter"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding OnlyShowDifferentParameters}" />
                <CheckBox Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IgnoreCaseValues}">
                    <TextBlock Text="Ignore Value Case" VerticalAlignment="Center" />
                </CheckBox>
            </StackPanel>

            <DataGrid x:Name="DifferencesDataGrid"
                      Grid.Row="2"
                      ItemsSource="{Binding DifferencesView}"
                      AutoGenerateColumns="False"
                      Margin="0,0,0,10"
                      MouseLeftButtonUp="DifferencesDataGrid_MouseLeftButtonUp">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="Auto" Header="">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          Visibility="{Binding HasChildren, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          Checked="ExpandCollapseCheckBox_OnChecked"
                                          Unchecked="ExpandCollapseCheckBox_OnChecked" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Name" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"
                                           Margin="{Binding Level, Converter={StaticResource IndentationConverter}}"
                                           Foreground="Black" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Left XML Value"
                                          Binding="{Binding LeftValue}"
                                          Width="*"
                                          IsReadOnly="True">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="Black" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLeftMissing}" Value="True">
                                        <Setter Property="Background" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Right XML Value"
                                          Binding="{Binding RightValue}"
                                          Width="*"
                                          IsReadOnly="True">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="Black" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRightMissing}" Value="True">
                                        <Setter Property="Background" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ResultSummary}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <Button Grid.Column="1"
                        Content="Export"
                        Width="120"
                        HorizontalAlignment="Right"
                        Command="{Binding ExportCommand}" />
            </Grid>
        </Grid>

        <Border Margin="10"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Width="60" Height="60">
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Grid.Loaded">
                            <BeginStoryboard x:Name="SpinnerStoryboardAction">
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinnerArcRotate"
                                                     Storyboard.TargetProperty="Angle"
                                                     From="0" To="360"
                                                     Duration="0:0:1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Grid.Unloaded">
                            <StopStoryboard BeginStoryboardName="SpinnerStoryboardAction" />
                        </EventTrigger>
                    </Grid.Triggers>
                    <Ellipse Width="48" Height="48" Stroke="LightGray" StrokeThickness="6" Opacity="0.3" />
                    <Path Stroke="#FF0078D7" StrokeThickness="6" StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                        <Path.Data>
                            <PathGeometry>
                                <PathFigure StartPoint="30,12" IsClosed="False">
                                    <ArcSegment Point="30,48" Size="18,18" SweepDirection="Clockwise" IsLargeArc="False" />
                                </PathFigure>
                            </PathGeometry>
                        </Path.Data>
                        <Path.RenderTransform>
                            <RotateTransform x:Name="SpinnerArcRotate" CenterX="24" CenterY="24" />
                        </Path.RenderTransform>
                    </Path>
                </Grid>
                <TextBlock Text="Comparing..." FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
