<Window x:Class="XmlDiffTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="XML Diff Tool" Height="600" Width="900">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="10" BorderThickness="1" BorderBrush="LightGray" CornerRadius="4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBox Width="280" Margin="0,0,8,0" Text="{Binding LeftFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                        <Button Content="Browse..." Width="90" Command="{Binding BrowseLeftCommand}" />
                    </StackPanel>

                    <Button Grid.Column="1" Content="Compare" Width="120" Margin="10,0" Command="{Binding CompareCommand}" />

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBox Width="280" Margin="0,0,8,0" Text="{Binding RightFilePath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                        <Button Content="Browse..." Width="90" Command="{Binding BrowseRightCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,10" VerticalAlignment="Center">
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Width="240" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
                <CheckBox Content="Only Show Different Parameter"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding OnlyShowDifferentParameters}" />
                <CheckBox Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          IsChecked="{Binding IgnoreCaseValues}">
                    <TextBlock Text="Ignore Value Case" VerticalAlignment="Center" />
                </CheckBox>
            </StackPanel>

            <DataGrid x:Name="DifferencesDataGrid"
                      Grid.Row="2"
                      ItemsSource="{Binding DifferencesView}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="0,0,0,10"
                      MouseLeftButtonUp="DifferencesDataGrid_MouseLeftButtonUp">
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="#FFECECEC" Padding="8,4" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Name, StringFormat=Tag: {0}}"
                                               FontWeight="Bold"
                                               FontSize="14" />
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </DataGrid.GroupStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Attribute" Binding="{Binding DisplayName}" Width="2*">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="Black" />
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Left XML Value" Binding="{Binding LeftValue}" Width="*">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="Black" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLeftMissing}" Value="True">
                                        <Setter Property="Background" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Right XML Value" Binding="{Binding RightValue}" Width="*">
                        <DataGridTextColumn.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="Black" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRightMissing}" Value="True">
                                        <Setter Property="Background" Value="Red" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.CellStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding ResultSummary}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0" />
                <Button Grid.Column="1"
                        Content="Export"
                        Width="120"
                        HorizontalAlignment="Right"
                        Command="{Binding ExportCommand}" />
            </Grid>
        </Grid>

        <Border Margin="10"
                Background="#80FFFFFF"
                Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="1">
            <Border Width="320"
                    Padding="20"
                    Background="White"
                    BorderBrush="#FFD0D0D0"
                    BorderThickness="1"
                    CornerRadius="8"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="{Binding ProgressText}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <ProgressBar Margin="0,16,0,0"
                                 Height="18"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding ProgressPercentage}" />
                    <TextBlock Text="{Binding ProgressPercentage, StringFormat={}{0}%}"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               FontWeight="Medium" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
